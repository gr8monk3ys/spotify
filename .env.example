# =============================================================================
# SpotifyForge Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables use the SPOTIFYFORGE_ prefix and map directly to the
# Settings class in spotifyforge/config.py.

# -----------------------------------------------------------------------------
# Spotify OAuth credentials (required)
# Get these from https://developer.spotify.com/dashboard
# -----------------------------------------------------------------------------
SPOTIFYFORGE_SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFYFORGE_SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFYFORGE_SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Path to the SQLite database file. Parent directories are created automatically.
SPOTIFYFORGE_DB_PATH=~/.spotifyforge/spotifyforge.db

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
# Host and port for the FastAPI/Uvicorn server.
SPOTIFYFORGE_WEB_HOST=127.0.0.1
SPOTIFYFORGE_WEB_PORT=8000

# Comma-separated list of allowed CORS origins (optional).
# Defaults to localhost:3000, :5173, and :8000 if unset.
# SPOTIFYFORGE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Scheduling
# -----------------------------------------------------------------------------
# Set to false to disable the APScheduler background scheduler.
SPOTIFYFORGE_SCHEDULER_ENABLED=true

# -----------------------------------------------------------------------------
# Cache TTLs (in seconds)
# -----------------------------------------------------------------------------
# How long various data types are considered fresh before re-fetching.
# 0 = cache indefinitely (until manually invalidated).
SPOTIFYFORGE_CACHE_TTL_AUDIO_FEATURES=0
SPOTIFYFORGE_CACHE_TTL_TRACK_METADATA=604800
SPOTIFYFORGE_CACHE_TTL_ARTIST_DATA=86400
SPOTIFYFORGE_CACHE_TTL_PLAYLIST_CONTENTS=3600
